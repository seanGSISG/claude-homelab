# Sanoid Configuration Template for Homelab
# Version: 1.0.0
# Last Updated: 2026-02-08
# Copy to /etc/sanoid/sanoid.conf and customize

# Production datasets (important data)
[tank/important]
	use_template = production
	recursive = yes
	process_children_only = yes

# Media datasets (less critical)
[tank/media]
	use_template = backup
	recursive = yes

# Backup datasets (long retention)
[backup/device1]
	use_template = backup_target
	recursive = yes

[backup/device2]
	use_template = backup_target
	recursive = yes

[backup/device3]
	use_template = backup_target
	recursive = yes

[backup/device4]
	use_template = backup_target
	recursive = yes

[backup/device5]
	use_template = backup_target
	recursive = yes

###############################################################################
# Templates
###############################################################################

# Production template: Short retention for sources
[template_production]
	frequently = 0          # Disable frequent snapshots
	hourly = 24             # Keep 24 hours
	daily = 30              # Keep 30 days
	weekly = 12             # Keep 12 weeks
	monthly = 36            # Keep 36 months
	yearly = 0              # Disable yearly
	autosnap = yes          # Automatically create snapshots
	autoprune = yes         # Automatically prune old snapshots

# Backup template: Minimal retention for media
[template_backup]
	frequently = 0
	hourly = 0              # No hourly on media
	daily = 30
	weekly = 8
	monthly = 12
	yearly = 0
	autosnap = yes
	autoprune = yes

# Backup target template: Long retention for backup server
[template_backup_target]
	frequently = 0
	hourly = 48             # Keep 2 days
	daily = 90              # Keep 3 months
	weekly = 12             # Keep 3 months
	monthly = 36            # Keep 3 years
	yearly = 0
	autosnap = no           # Don't snap on backup (snapshots come from sources)
	autoprune = yes         # Prune old snapshots
