# =============================================================================
# HOMELAB ENVIRONMENT CONFIGURATION (EXAMPLE)
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# AUTHELIA (AUTHENTICATION MONITORING)
# =============================================================================
AUTHELIA_URL=https://auth.example.com
AUTHELIA_USERNAME=admin
AUTHELIA_PASSWORD=your_password
AUTHELIA_API_TOKEN=  # Optional: leave empty for cookie-based auth

# =============================================================================
# UNIFI CONTROLLER
# =============================================================================
UNIFI_URL=https://your-unifi-controller-ip
UNIFI_USERNAME=your_username
UNIFI_PASSWORD=your_password
UNIFI_SITE=default

# =============================================================================
# LINKDING (BOOKMARK MANAGER)
# =============================================================================
LINKDING_URL=https://your-linkding-url
LINKDING_API_KEY=your_api_key

# =============================================================================
# RADARR (MOVIE MANAGEMENT)
# =============================================================================
RADARR_URL=https://your-radarr-url
RADARR_API_KEY=your_api_key
RADARR_DEFAULT_QUALITY_PROFILE=1

# =============================================================================
# SONARR (TV SERIES MANAGEMENT)
# =============================================================================
SONARR_URL=https://your-sonarr-url
SONARR_API_KEY=your_api_key
SONARR_DEFAULT_QUALITY_PROFILE=1

# =============================================================================
# PROWLARR (INDEXER MANAGER)
# =============================================================================
PROWLARR_URL=https://your-prowlarr-url
PROWLARR_API_KEY=your_api_key

# =============================================================================
# PAPERLESS-NGX (DOCUMENT MANAGEMENT)
# =============================================================================
PAPERLESS_URL=https://paperless.tootie.tv
PAPERLESS_API_TOKEN=your_api_token

# =============================================================================
# OVERSEERR (MEDIA REQUEST MANAGEMENT)
# =============================================================================
OVERSEERR_URL=https://your-overseerr-url
OVERSEERR_API_KEY=your_api_key

# =============================================================================
# SABNZBD (USENET DOWNLOADER)
# =============================================================================
SABNZBD_URL=https://your-sabnzbd-url
SABNZBD_API_KEY=your_api_key

# =============================================================================
# QBITTORRENT (TORRENT CLIENT)
# =============================================================================
QBITTORRENT_URL=https://your-qbittorrent-url
QBITTORRENT_USERNAME=your_username
QBITTORRENT_PASSWORD=your_password

# =============================================================================
# GOTIFY (NOTIFICATION SERVER)
# =============================================================================
GOTIFY_URL=https://your-gotify-url
GOTIFY_TOKEN=your_token

# =============================================================================
# GLANCES (SYSTEM MONITORING)
# =============================================================================
GLANCES_URL=http://your-host:61208
GLANCES_USERNAME=
GLANCES_PASSWORD=

# =============================================================================
# TAILSCALE (VPN/MESH NETWORK)
# =============================================================================
TAILSCALE_API_KEY=your_api_key
TAILSCALE_TAILNET=your_tailnet_or_dash

# =============================================================================
# UNRAID SERVERS
# =============================================================================
# Unraid Server 1
UNRAID_TOOTIE_NAME=server1_name
UNRAID_TOOTIE_URL=https://your-unraid-server1-url/graphql
UNRAID_TOOTIE_API_KEY=your_api_key

# Unraid Server 2
UNRAID_SHART_NAME=server2_name
UNRAID_SHART_URL=https://your-unraid-server2-url/graphql
UNRAID_SHART_API_KEY=your_api_key

# =============================================================================
# PLEX MEDIA SERVER
# =============================================================================
PLEX_URL=https://your-plex-url:32400
PLEX_TOKEN=your_x_plex_token

# =============================================================================
# TAUTULLI (PLEX ANALYTICS & MONITORING)
# =============================================================================
TAUTULLI_URL=https://tautulli.tootie.tv
TAUTULLI_API_KEY=your_api_key

# =============================================================================
# FIRECRAWL (WEB SCRAPING/CRAWLING)
# =============================================================================
# Cloud API (recommended)
FIRECRAWL_API_KEY=fc-your_api_key
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Self-hosted instance (alternative)
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=http://localhost:3002

# =============================================================================
# BYTESTASH (CODE SNIPPET MANAGER)
# =============================================================================
BYTESTASH_URL=https://your-bytestash-url
BYTESTASH_API_KEY=your_api_key

# =============================================================================
# MEMOS (NOTE-TAKING SERVICE)
# =============================================================================
MEMOS_URL=https://your-memos-url
MEMOS_API_TOKEN=your_jwt_token

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================
# Add any additional environment variables below
