# =============================================================================
# Claude Homelab — Credential Template
# =============================================================================
# Copy this file to ~/.claude-homelab/.env and fill in your values.
# Or use the interactive wizard: /homelab-core:setup in Claude Code
#
# SECURITY: Never commit .env to version control. Keep chmod 600.
# =============================================================================

# =============================================================================
# MEDIA
# =============================================================================

# PLEX MEDIA SERVER
PLEX_URL=https://your-plex-url:32400
PLEX_TOKEN=your_x_plex_token

# RADARR (MOVIE MANAGEMENT)
RADARR_URL=https://your-radarr-url
RADARR_API_KEY=your_api_key

# SONARR (TV SERIES MANAGEMENT)
SONARR_URL=https://your-sonarr-url
SONARR_API_KEY=your_api_key

# OVERSEERR (MEDIA REQUEST MANAGEMENT)
OVERSEERR_URL=https://your-overseerr-url
OVERSEERR_API_KEY=your_api_key

# PROWLARR (INDEXER MANAGER)
PROWLARR_URL=https://your-prowlarr-url
PROWLARR_API_KEY=your_api_key

# TAUTULLI (PLEX ANALYTICS)
TAUTULLI_URL=https://your-tautulli-url
TAUTULLI_API_KEY=your_api_key

# =============================================================================
# DOWNLOADS
# =============================================================================

# QBITTORRENT (TORRENT CLIENT)
QBITTORRENT_URL=https://your-qbittorrent-url
QBITTORRENT_USERNAME=your_username
QBITTORRENT_PASSWORD=your_password

# SABNZBD (USENET DOWNLOADER)
SABNZBD_URL=https://your-sabnzbd-url
SABNZBD_API_KEY=your_api_key

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# UNRAID — supports up to two servers
# Server 1
UNRAID_SERVER1_NAME=your_server1_name
UNRAID_SERVER1_URL=https://your-unraid-server1/graphql
UNRAID_SERVER1_API_KEY=your_api_key

# Server 2 (optional)
UNRAID_SERVER2_NAME=your_server2_name
UNRAID_SERVER2_URL=https://your-unraid-server2/graphql
UNRAID_SERVER2_API_KEY=your_api_key

# UNIFI CONTROLLER
UNIFI_URL=https://your-unifi-controller-ip
UNIFI_USERNAME=your_username
UNIFI_PASSWORD=your_password
UNIFI_SITE=default

# TAILSCALE (VPN/MESH NETWORK)
TAILSCALE_API_KEY=your_api_key
TAILSCALE_TAILNET=your_tailnet_or_dash

# ZFS — no credentials needed, uses local CLI

# =============================================================================
# SECURITY
# =============================================================================

# FAIL2BAN/SWAG — uses local system access, no credentials needed

# =============================================================================
# UTILITIES
# =============================================================================

# GOTIFY (PUSH NOTIFICATIONS)
GOTIFY_URL=https://your-gotify-url
GOTIFY_TOKEN=your_token

# LINKDING (BOOKMARKS)
LINKDING_URL=https://your-linkding-url
LINKDING_API_KEY=your_api_key

# MEMOS (NOTES)
MEMOS_URL=https://your-memos-url
MEMOS_API_TOKEN=your_jwt_token

# BYTESTASH (CODE SNIPPETS)
BYTESTASH_URL=https://your-bytestash-url
BYTESTASH_API_KEY=your_api_key

# PAPERLESS-NGX (DOCUMENT MANAGEMENT)
PAPERLESS_URL=https://your-paperless-url
PAPERLESS_API_TOKEN=your_api_token

# RADICALE (CALENDAR + CONTACTS — CalDAV/CardDAV)
RADICALE_URL=https://your-radicale-url
RADICALE_USERNAME=your_username
RADICALE_PASSWORD=your_password

# NUGS — uses config file at ~/.nugs/config.json, not this .env
